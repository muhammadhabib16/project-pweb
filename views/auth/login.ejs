<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login | Lembur B06</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Poppins', sans-serif;
    }

    body {
      width: 100%;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      overflow: hidden;
      position: relative;
      background: #0f172a;
      padding: 40px;
    }

    body::before {
      content: "";
      position: absolute;
      inset: 0;
      background: url('/images/login-bg.png') center/cover no-repeat;
      filter: blur(5px) brightness(0.55);
      transform: scale(1.06);
      z-index: -2;
    }

    body::after {
      content: "";
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.28);
      z-index: -1;
    }

    .login-container {
      width: 1120px;
      height: 720px;
      display: flex;
      border-radius: 35px;
      overflow: hidden;
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(12px);
      box-shadow: 0 20px 45px rgba(0,0,0,0.45);
      animation: fadeIn .8s ease;
    }

    .left-side {
      flex: 1;
      background: rgba(255,255,255,0.06);
      backdrop-filter: blur(10px);
      display: flex;
      justify-content: center;
      align-items: center;
      text-align: center;
    }

    .left-content {
      color: white;
      padding: 60px;
      max-width: 520px;
    }

    .left-content h2 {
      font-size: 48px;
      line-height: 1.1;
      font-weight: 900;
      margin-bottom: 20px;
      text-shadow: 0 5px 15px rgba(0,0,0,.45);
    }

    .left-content p {
      font-size: 18px;
      line-height: 1.6;
      color: #f1f5f9;
      font-weight: 500;
      text-shadow: 0 4px 12px rgba(0,0,0,.45);
    }

    .right-side {
      width: 590px;
      background: white;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 75px 75px;
      border-radius: 0 35px 35px 0;
    }

    .login-box {
      width: 100%;
      max-width: 420px;
    }

    .login-box h1 {
      font-size: 50px;
      line-height: 1.08;
      font-weight: 900;
      color: #111827;
      margin-bottom: 16px;
    }

    .login-box h1 span {
      display: block;
      color: #22c55e;
    }

    .subtitle {
      color: #6b7280;
      font-size: 16px;
      margin-bottom: 38px;
    }

    .error-msg {
      background: #fee2e2;
      color: #dc2626;
      padding: 12px 14px;
      border-radius: 12px;
      margin-bottom: 20px;
      font-size: 14px;
    }

    .input-group {
      margin-bottom: 26px;
    }

    .input-group label {
      display: block;
      margin-bottom: 10px;
      font-size: 15px;
      font-weight: 600;
      color: #444;
    }

    .input-group input {
      width: 100%;
      height: 58px;
      border: none;
      outline: none;
      border-radius: 16px;
      background: #f3f4f6;
      padding: 0 20px;
      font-size: 16px;
      color: #111827;
      transition: .25s ease;
    }

    .input-group input:focus {
      background: #fff;
      border: 2px solid #22c55e;
      box-shadow: 0 0 12px rgba(34,197,94,.18);
    }

    .forgot {
      text-align: right;
      margin-top: -6px;
      margin-bottom: 30px;
    }

    .forgot a {
      text-decoration: none;
      color: #666;
      font-size: 14px;
      transition: .25s;
    }

    .forgot a:hover {
      color: #22c55e;
    }

    .login-btn {
      width: 100%;
      height: 60px;
      border: none;
      border-radius: 16px;
      background: #22c55e;
      color: white;
      font-size: 18px;
      font-weight: 800;
      cursor: pointer;
      transition: .3s;
      box-shadow: 0 10px 22px rgba(34,197,94,.32);
    }

    .login-btn:hover {
      transform: translateY(-3px);
      background: #16a34a;
    }

    .divider {
      display: flex;
      align-items: center;
      gap: 14px;
      margin: 34px 0 22px;
      color: #777;
      font-size: 14px;
      white-space: nowrap;
    }

    .divider::before,
    .divider::after {
      content: "";
      flex: 1;
      height: 1px;
      background: #ddd;
    }

    .social-login {
      display: flex;
      gap: 16px;
    }

    .social-btn {
      flex: 1;
      height: 58px;
      border: none;
      border-radius: 16px;
      background: #f3f4f6;
      color: #111827;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      transition: .25s;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 10px;
    }

    .social-btn:hover {
      background: #e5e7eb;
      transform: translateY(-2px);
    }

    .google i {
      color: #4285F4;
    }

    .apple i {
      color: #111;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(28px) scale(.96);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }

    @media(max-width: 950px) {
      body {
        overflow: auto;
        padding: 25px 0;
      }

      .login-container {
        width: 92%;
        height: auto;
        flex-direction: column;
      }

      .left-side {
        min-height: 260px;
      }

      .left-content {
        padding: 35px;
      }

      .left-content h2 {
        font-size: 34px;
      }

      .left-content p {
        font-size: 14px;
      }

      .right-side {
        width: 100%;
        border-radius: 0 0 35px 35px;
        padding: 55px 38px;
      }

      .login-box {
        max-width: 100%;
      }

      .login-box h1 {
        font-size: 42px;
      }

      .subtitle {
        margin-bottom: 32px;
      }

      .social-login {
        flex-direction: column;
      }

      .social-btn {
        width: 100%;
      }
    }
  </style>
</head>

<body>

  <div class="login-container">

    <div class="left-side">
      <div class="left-content">
        <h2>Lembur B06</h2>
        <p>
          Sistem pengelolaan lembur modern dengan tampilan elegan dan responsif.
        </p>
      </div>
    </div>

    <div class="right-side">
      <div class="login-box">

        <h1>
          Masuk
          <span>Sekarang</span>
        </h1>

        <p class="subtitle">Selamat datang kembali 👋</p>

        <% if (typeof error !== "undefined" && error) { %>
          <div class="error-msg">
            <%= error %>
          </div>
        <% } %>

        <form action="/login" method="POST">

          <div class="input-group">
            <label>Username</label>
            <input
              type="text"
              name="username"
              placeholder="Masukkan username"
              required
            >
          </div>

          <div class="input-group">
            <label>Password</label>
            <input
              type="password"
              name="password"
              placeholder="Masukkan password"
              required
            >
          </div>

          <div class="forgot">
            <a href="#">Lupa password?</a>
          </div>

          <button type="submit" class="login-btn">
            Masuk
          </button>

        </form>

        <div class="divider">
          atau masuk dengan
        </div>

        <div class="social-login">
          <button type="button" class="social-btn google">
            <i class="fa-brands fa-google"></i>
            Google
          </button>

          <button type="button" class="social-btn apple">
            <i class="fa-brands fa-apple"></i>
            Apple
          </button>
        </div>

      </div>
    </div>

  </div>

</body>
</html>