<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login | Lembur B06</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(135deg, #143b2a, #d8e4dd);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .container {
      width: 1080px;
      height: 650px;
      background: #fff;
      border-radius: 32px;
      overflow: hidden;
      position: relative;
      box-shadow: 0 25px 55px rgba(0, 0, 0, 0.3);
    }

    .form-container {
      position: absolute;
      top: 0;
      width: 50%;
      height: 100%;
      background: #fff;
      padding: 72px 68px;
      transition: all 0.7s ease-in-out;
    }

    .login-container {
      left: 0;
      z-index: 2;
    }

    .register-container {
      left: 0;
      opacity: 0;
      z-index: 1;
    }

    .container.active .login-container {
      transform: translateX(100%);
      opacity: 0;
      z-index: 1;
    }

    .container.active .register-container {
      transform: translateX(100%);
      opacity: 1;
      z-index: 3;
    }

    h2 {
      font-size: 48px;
      margin: 0 0 36px;
      font-weight: 900;
      color: #111;
    }

    .input-group {
      margin-bottom: 14px;
    }

    .input-group label {
      display: block;
      font-size: 13px;
      color: #555;
      margin-bottom: 6px;
    }

    .input-group input {
      width: 100%;
      border: none;
      border-bottom: 2px solid #999;
      padding: 10px 4px;
      outline: none;
      font-size: 15px;
      background: transparent;
      font-size: 17px;
      padding: 14px 4px;
    }

    .input-group input:focus {
      border-bottom-color: #22c55e;
    }

    .row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin: 20px 0 28px;
      font-size: 14px;
    }

    .remember {
      display: flex;
      align-items: center;
      gap: 6px;
      color: #333;
    }

    .row a {
      color: #333;
      text-decoration: none;
      max-width: 145px;
      text-align: right;
    }

    .main-btn {
      width: 100%;
      border: none;
      background: #5f6675;
      color: white;
      padding: 18px;
      border-radius: 22px;
      font-weight: bold;
      font-size: 18px;
      cursor: pointer;
    }

    .main-btn:hover {
      background: #22c55e;
    }

    .social-text {
      text-align: center;
      margin-top: 22px;
      font-weight: bold;
      font-size: 14px;
    }

    .social-icons {
      display: flex;
      justify-content: center;
      gap: 18px;
      margin-top: 10px;
}

    .social-icons button {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      border: 1px solid #eee;
      background: white;
      font-weight: bold;
      cursor: pointer;
      box-shadow: 0 5px 15px rgba(0,0,0,.08);
    }

    .overlay-container {
      position: absolute;
      top: 0;
      left: 50%;
      width: 50%;
      height: 100%;
      overflow: hidden;
      transition: transform 0.7s ease-in-out;
      z-index: 10;
    }

    .container.active .overlay-container {
      transform: translateX(-100%);
    }

    .overlay {
      width: 200%;
      height: 100%;
      position: relative;
      left: -100%;
      transform: translateX(0);
      transition: transform 0.7s ease-in-out;
      background:
        linear-gradient(rgba(25, 45, 38, .58), rgba(25, 45, 38, .58)),
        url('/images/login-bg.png');
      background-size: cover;
      background-position: center;
      color: white;
    }

    .container.active .overlay {
      transform: translateX(50%);
    }

    .overlay-panel {
      position: absolute;
      top: 0;
      width: 50%;
      height: 100%;
      padding: 60px 45px;
      text-align: center;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 60px 55px;
    }

    .overlay-left {
      left: 0;
    }

    .overlay-right {
      right: 0;
    }

    .overlay-panel h1 {
      font-size: 54px;
      line-height: 1.05;
      margin: 0 0 22px;
      font-weight: 900;
      text-shadow: 0 4px 12px rgba(0,0,0,.6);
      max-width: 420px;
      margin-inline: auto;
}

    .overlay-panel p {
      font-size: 18px;
      line-height: 1.5;
      margin-bottom: 35px;
      text-shadow: 0 3px 10px rgba(0,0,0,.6);
    }

    .ghost-btn {
      border: 2px solid white;
      background: rgba(255,255,255,.12);
      color: white;
      padding: 18px 58px;
      border-radius: 22px;
      font-weight: bold;
      cursor: pointer;
      backdrop-filter: blur(5px);
      font-size: 17px;
    }

    .ghost-btn:hover {
      background: rgba(34,197,94,.35);
      border-color: #22c55e;
    }

    .error-msg {
      color: #dc2626;
      background: #fee2e2;
      padding: 10px 12px;
      border-radius: 10px;
      margin-bottom: 18px;
      font-size: 14px;
    }

    @media (max-width: 768px) {
      .container {
        width: 92%;
        height: auto;
        min-height: 760px;
      }

      .form-container,
      .overlay-container {
        width: 100%;
        height: 50%;
      }

      .login-container,
      .register-container {
        left: 0;
        top: 50%;
      }

      .container.active .login-container {
        transform: translateY(0);
        opacity: 0;
      }

      .container.active .register-container {
        transform: translateY(0);
        opacity: 1;
      }

      .overlay-container {
        left: 0;
        top: 0;
      }

      .container.active .overlay-container {
        transform: translateY(0);
      }

      .overlay {
        width: 100%;
        left: 0;
      }

      .container.active .overlay {
        transform: none;
      }

      .overlay-panel {
        width: 100%;
      }

      .overlay-left,
      .overlay-right {
        left: 0;
        right: auto;
      }

      .overlay-left {
        display: none;
      }

      .container.active .overlay-left {
        display: flex;
      }

      .container.active .overlay-right {
        display: none;
      }

      .form-container {
        padding: 38px 30px;
      }

      .overlay-panel h1 {
        font-size: 34px;
      }
    }
  </style>
</head>

<body>
  <div class="container" id="container">

    <div class="form-container register-container">
      <h2>Daftar di sini</h2>

      <form action="/register" method="POST">
        <div class="input-group">
          <label>Nama</label>
          <input type="text" name="name" required />
        </div>

        <div class="input-group">
          <label>Email</label>
          <input type="text" name="email" required />
        </div>

        <div class="input-group">
          <label>Password</label>
          <input type="password" name="password" required />
        </div>

        <button type="submit" class="main-btn">Daftar</button>
      </form>

      <p class="social-text">Atau gunakan akun</p>

      <div class="social-icons">
        <button type="button">f</button>
        <button type="button">G</button>
        <button type="button">♪</button>
      </div>
    </div>

    <div class="form-container login-container">
      <h2>Masuk di sini</h2>

      <% if (typeof error !== "undefined" && error) { %>
        <div class="error-msg"><%= error %></div>
      <% } %>

      <form action="/login" method="POST">
        <div class="input-group">
          <label>Email</label>
          <input type="text" name="email" required />
        </div>

        
        <div class="input-group">
          <label>Password</label>
          <input type="password" name="password" required />
        </div>

        <div class="row">
          <label class="remember">
            <input type="checkbox" />
            Ingat saya
          </label>

          <a href="#">Lupa password?</a>
        </div>

        <button type="submit" class="main-btn">Masuk</button>
      </form>

      <p class="social-text">Atau gunakan akun</p>

      <div class="social-icons">
        <button type="button">f</button>
        <button type="button">G</button>
        <button type="button">♪</button>
      </div>
    </div>

    <div class="overlay-container">
      <div class="overlay">
        <div class="overlay-panel overlay-left">
          <h1>Halo<br>teman!</h1>
          <p>Sudah punya akun? Masuk dan lanjutkan aktivitas lemburmu.</p>
          <button class="ghost-btn" id="loginBtn">← Masuk</button>
        </div>

        <div class="overlay-panel overlay-right">
          <h1>Sistem<br>Lembur</h1>
          <p>Belum punya akun? Daftar sekarang dan mulai gunakan aplikasi.</p>
          <button class="ghost-btn" id="registerBtn">Daftar →</button>
        </div>
      </div>
    </div>

  </div>

  <script>
    const container = document.getElementById("container");
    const registerBtn = document.getElementById("registerBtn");
    const loginBtn = document.getElementById("loginBtn");

    registerBtn.addEventListener("click", () => {
      container.classList.add("active");
    });

    loginBtn.addEventListener("click", () => {
      container.classList.remove("active");
    });
  </script>
</body>
</html>